{
  "name": "claude-md-coach",
  "version": "0.1.0",
  "description": "Ambient coach for your CLAUDE.md files. Learns from your chat history, finds dead rules, suggests missing ones, rewrites smarter.",
  "bin": {
    "claude-md-coach": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "scan": "tsc && node dist/cli.js scan",
    "start": "node dist/cli.js"
  },
  "keywords": ["claude", "claude-code", "claude-md", "audit", "prompt-optimization"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
